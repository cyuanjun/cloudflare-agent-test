{
  "name": "cloudflare-agent-test-v2",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-02",
  "limits": {
    "subrequests": 2000
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "RUN_AGENT",
        "class_name": "RunAgent"
      },
      {
        "name": "DATASET_CACHE",
        "class_name": "SharedDataset"
      },
      {
        "name": "AGENT_REGISTRY",
        "class_name": "AgentRegistry"
      }
    ]
  },
  "triggers": {
    "crons": ["0 */6 * * *"]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RunAgent", "SharedDataset"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["AgentRegistry"]
    }
  ]
}
