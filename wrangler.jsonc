{
  "name": "cloudflare-agent-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-02",
  "durable_objects": {
    "bindings": [
      {
        "name": "RUN_AGENT",
        "class_name": "RunAgent"
      },
      {
        "name": "DATASET_CACHE",
        "class_name": "SharedDataset"
      }
    ]
  },
  "triggers": {
    "crons": ["0 */6 * * *"]
  },
  "migrations": [
    {
      "tag": "v2",
      "new_sqlite_classes": ["RunAgent", "SharedDataset"]
    }
  ]
}
